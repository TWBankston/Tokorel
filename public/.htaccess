DirectoryIndex index.html

# Process PHP files
AddHandler application/x-httpd-php .php

# Protect auth config from direct web access
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Rewrite rules for clean URLs
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Page rewrites (must come before the directory check since
    # Next.js generates both page.html and page/ directories)
    RewriteRule ^download$ /download.html [L]
    RewriteRule ^login$ /login.html [L]
    RewriteRule ^portal$ /portal.html [L]
    RewriteRule ^admin$ /admin.html [L]
    RewriteRule ^subscribe$ /subscribe.php [L]

    # Don't rewrite actual files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>
